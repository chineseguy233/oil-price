<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>油价守护者 - 智能油价监测</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://map.qq.com/api/gljs?v=1.exp&key=NVLBZ-UIDC4-YTFUP-KMHA5-BGBGF-HZFNH"></script>
  <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
  <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/echarts@5.4.3/dist/echarts.min.js"></script>
  <style>
    :root {
      --primary: #2563EB;
      --rise: #EF4444;
      --fall: #22C55E;
      --bg: #F8FAFC;
    }
    body { background: var(--bg); font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
    .price-up { color: var(--rise); }
    .price-down { color: var(--fall); }
    .card { background: white; border-radius: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
    .tab-active { color: var(--primary); border-bottom: 3px solid var(--primary); }
  </style>
</head>
<body>
  <div id="root"></div>
  
  <script type="text/babel">
    const { useState, useEffect, useRef } = React;

    // Haversine 公式计算两点间距离(公里)
    function calculateDistance(lat1, lng1, lat2, lng2) {
      const R = 6371; // 地球半径(公里)
      const dLat = (lat2 - lat1) * Math.PI / 180;
      const dLng = (lng2 - lng1) * Math.PI / 180;
      const a = Math.sin(dLat/2) * Math.sin(dLat/2) +
                Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
                Math.sin(dLng/2) * Math.sin(dLng/2);
      const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
      return R * c;
    }

    // 格式化距离
    function formatDistance(km) {
      if (km < 1) {
        return Math.round(km * 1000) + 'm';
      }
      return km.toFixed(1) + 'km';
    }


    const API_BASE = "http://localhost:3000/api";

    

    const mockTrend7Days = [
      { date: '3-10', '92': 7.78, '95': 8.30, '0': 7.48 },
      { date: '3-11', '92': 7.80, '95': 8.32, '0': 7.50 },
      { date: '3-12', '92': 7.82, '95': 8.35, '0': 7.52 },
      { date: '3-13', '92': 7.85, '95': 8.36, '0': 7.55 },
      { date: '3-14', '92': 7.83, '95': 8.34, '0': 7.53 },
      { date: '3-15', '92': 7.85, '95': 8.36, '0': 7.58 },
      { date: '3-16', '92': 7.85, '95': 8.36, '0': 7.58 },
    ];

    // 首页 - 油价查询
    function OilPricePage({ selectedRegion, setSelectedRegion }) {
      const [oilData, setOilData] = useState({});
      const [loading, setLoading] = useState(true);
      const [updateTime, setUpdateTime] = useState('');
      const [oilType, setOilType] = useState('92');
      
      // 省市区选择
      const [province, setProvince] = useState('北京');
      const [city, setCity] = useState('北京市');
      const [county, setCounty] = useState('');
      
      // 省市区数据
      const PROVINCES = {
        '北京': ['北京市'], '上海': ['上海市'], '天津': ['天津市'], '重庆': ['重庆市'],
        '广东': ['广州市', '韶关市', '深圳市', '珠海市', '汕头市', '佛山市', '江门市', '湛江市', '茂名市', '肇庆市', '惠州市', '梅州市', '汕尾市', '河源市', '阳江市', '清远市', '东莞市', '中山市', '潮州市', '揭阳市', '云浮市'],
        '江苏': ['南京市', '无锡市', '徐州市', '常州市', '苏州市', '南通市', '连云港市', '淮安市', '盐城市', '扬州市', '镇江市', '泰州市', '宿迁市'],
        '浙江': ['杭州市', '宁波市', '温州市', '嘉兴市', '湖州市', '绍兴市', '金华市', '衢州市', '舟山市', '台州市', '丽水市'],
        '山东': ['济南市', '青岛市', '淄博市', '枣庄市', '东营市', '烟台市', '潍坊市', '济宁市', '泰安市', '威海市', '日照市', '莱芜市', '临沂市', '德州市', '聊城市', '滨州市', '菏泽市'],
        '河北': ['石家庄市', '唐山市', '秦皇岛市', '邯郸市', '邢台市', '保定市', '张家口市', '承德市', '沧州市', '廊坊市', '衡水市'],
        '河南': ['郑州市', '开封市', '洛阳市', '平顶山市', '安阳市', '鹤壁市', '新乡市', '焦作市', '濮阳市', '许昌市', '漯河市', '三门峡市', '南阳市', '商丘市', '信阳市', '周口市', '驻马店市', '济源市'],
        '四川': ['成都市', '自贡市', '攀枝花市', '泸州市', '德阳市', '绵阳市', '广元市', '遂宁市', '内江市', '乐山市', '南充市', '眉山市', '宜宾市', '广安市', '达州市', '雅安市', '巴中市', '资阳市'],
        '湖北': ['武汉市', '黄石市', '十堰市', '宜昌市', '襄阳市', '鄂州市', '荆门市', '孝感市', '荆州市', '黄冈市', '咸宁市', '随州市', '恩施州'],
        '湖南': ['长沙市', '株洲市', '湘潭市', '衡阳市', '邵阳市', '岳阳市', '常德市', '张家界市', '益阳市', '郴州市', '永州市', '怀化市', '娄底市', '湘西州'],
        '辽宁': ['沈阳市', '大连市', '鞍山市', '抚顺市', '本溪市', '丹东市', '锦州市', '营口市', '阜新市', '辽阳市', '盘锦市', '铁岭市', '朝阳市', '葫芦岛市'],
        '福建': ['福州市', '厦门市', '莆田市', '三明市', '泉州市', '漳州市', '南平市', '龙岩市', '宁德市'],
        '陕西': ['西安市', '铜川市', '宝鸡市', '咸阳市', '渭南市', '延安市', '汉中市', '榆林市', '安康市', '商洛市'],
        '山西': ['太原市', '大同市', '阳泉市', '长治市', '晋城市', '朔州市', '晋中市', '运城市', '忻州市', '临汾市', '吕梁市'],
        '安徽': ['合肥市', '芜湖市', '蚌埠市', '淮南市', '马鞍山市', '淮北市', '铜陵市', '安庆市', '黄山市', '滁州市', '阜阳市', '宿州市', '六安市', '亳州市', '池州市', '宣城市'],
        '江西': ['南昌市', '景德镇市', '萍乡市', '九江市', '新余市', '鹰潭市', '赣州市', '吉安市', '宜春市', '抚州市', '上饶市'],
        '吉林': ['长春市', '吉林市', '四平市', '辽源市', '通化市', '白山市', '松原市', '白城市', '延边州'],
        '黑龙江': ['哈尔滨市', '齐齐哈尔市', '鸡西市', '鹤岗市', '双鸭山市', '大庆市', '伊春市', '佳木斯市', '七台河市', '牡丹江市', '黑河市', '绥化市', '大兴安岭'],
        '甘肃': ['兰州市', '嘉峪关市', '金昌市', '白银市', '天水市', '武威市', '张掖市', '平凉市', '酒泉市', '庆阳市', '定西市', '陇南市', '临夏州', '甘南州'],
        '贵州': ['贵阳市', '六盘水市', '遵义市', '安顺市', '毕节市', '铜仁市', '黔西南州', '黔东南州', '黔南州'],
        '海南': ['海口市', '三亚市', '三沙市', '儋州市', '五指山市', '琼海市', '文昌市', '万宁市', '东方市'],
        '内蒙古': ['呼和浩特市', '包头市', '乌海市', '赤峰市', '通辽市', '鄂尔多斯市', '呼伦贝尔市', '巴彦淖尔市', '乌兰察布市', '兴安盟', '锡林郭勒盟', '阿拉善盟'],
        '广西': ['南宁市', '柳州市', '桂林市', '梧州市', '北海市', '防城港市', '钦州市', '贵港市', '玉林市', '百色市', '贺州市', '河池市', '来宾市', '崇左市'],
        '宁夏': ['银川市', '石嘴山市', '吴忠市', '固原市', '中卫市'],
        '青海': ['西宁市', '海东市', '海北州', '黄南州', '海南州', '果洛州', '玉树州', '海西州'],
        '新疆': ['乌鲁木齐市', '克拉玛依市', '吐鲁番市', '哈密市', '昌吉州', '博尔塔拉州', '巴音郭楞州', '阿克苏地区', '克孜勒苏州', '喀什地区', '和田地区', '伊犁州', '塔城地区', '阿勒泰地区'],
        '西藏': ['拉萨市', '日喀则市', '昌都市', '林芝市', '山南市', '那曲市', '阿里地区'],
        '云南': ['昆明市', '曲靖市', '玉溪市', '保山市', '昭通市', '丽江市', '普洱市', '临沧市', '楚雄州', '红河州', '文山州', '西双版纳州', '大理州', '德宏州', '怒江州', '迪庆州'],
      };
      
      // 市级数据(示例，实际应该从后端获取)
      const CITY_DATA = {
        '北京市': {'92': 7.64, '95': 8.13, '98': 9.63, '0': 7.34},
        '上海市': {'92': 7.60, '95': 8.09, '98': 10.09, '0': 7.28},
        '广州市': {'92': 7.66, '95': 8.29, '98': 9.88, '0': 7.30},
        '深圳市': {'92': 7.68, '95': 8.30, '98': 9.95, '0': 7.32},
        '杭州市': {'92': 7.65, '95': 8.14, '98': 9.68, '0': 7.35},
      };
      
      const cities = PROVINCES[province] || [province];
      
      useEffect(() => {
        fetch(API_BASE + '/oil-prices')
          .then(res => res.json())
          .then(data => {
            setOilData(data.prices || {});
            setUpdateTime(data.update_time || '');
            setLoading(false);
          })
          .catch(err => {
            console.error('Failed to fetch:', err);
            setLoading(false);
          });
      }, []);
      
      useEffect(() => {
        // 同步选择到父组件
        setSelectedRegion(city || province);
      }, [city, province]);
      
      const currentPrice = CITY_DATA[city]?.[oilType] || oilData[province]?.[oilType] || oilData[city]?.[oilType] || '--';
      const yesterdayPrice = 7.50;
      const change = currentPrice !== '--' ? currentPrice - yesterdayPrice : 0;
      const changePercent = currentPrice !== '--' ? ((change / yesterdayPrice) * 100).toFixed(2) : 0;

      if (loading) {
        return <div className="p-4 text-center text-gray-500">加载中...</div>;
      }
      
      return (
        <div className="p-4 pb-20">
          {/* 头部建议 */}
          <div className="card p-5 mb-4">
            <div className="text-sm text-gray-500 mb-1">今日油价 · {city || province}</div>
            <div className="text-3xl font-bold text-gray-800 mb-2">
              {currentPrice} <span className="text-lg font-normal">元/升</span>
            </div>
            {currentPrice !== '--' && (
              <div className={`text-sm ${change >= 0 ? 'price-up' : 'price-down'}`}>
                {change >= 0 ? '↑' : '↓'} 较昨日 {Math.abs(change)} 元 ({Math.abs(changePercent)}%)
              </div>
            )}
            <SmartSuggestion province={province} oilType={oilType} oilData={oilData} />
          </div>

          {/* 省市区选择 */}
          <div className="mb-4">
            <label className="text-sm text-gray-600 block mb-2">选择地区</label>
            
            {/* 省份选择 */}
            <select 
              value={province}
              onChange={(e) => {
                setProvince(e.target.value);
                setCity(PROVINCES[e.target.value]?.[0] || e.target.value);
                setCounty('');
              }}
              className="w-full p-3 border rounded-xl bg-white mb-2"
            >
              {Object.keys(PROVINCES).map(p => <option key={p} value={p}>{p}</option>)}
            </select>
            
            {/* 城市选择 */}
            {cities.length > 1 && (
              <select 
                value={city}
                onChange={(e) => {
                  setCity(e.target.value);
                  setCounty('');
                }}
                className="w-full p-3 border rounded-xl bg-white mb-2"
              >
                {cities.map(c => <option key={c} value={c}>{c}</option>)}
              </select>
            )}
            
            {/* 区县输入 (预留) */}
            {city && (
              <input 
                type="text"
                value={county}
                onChange={(e) => setCounty(e.target.value)}
                placeholder="精确到区县(可选)"
                className="w-full p-3 border rounded-xl bg-white"
              />
            )}
          </div>

          {/* 油号选择 */}
          <div className="flex gap-2 mb-4">
            {['92', '95', '98', '0'].map(type => (
              <button
                key={type}
                onClick={() => setOilType(type)}
                className={`flex-1 py-3 rounded-xl font-medium transition ${
                  oilType === type 
                    ? 'bg-blue-600 text-white' 
                    : 'bg-white text-gray-600 border'
                }`}
              >
                {type === '0' ? '0#柴油' : `${type}#汽油`}
              </button>
            ))}
          </div>

          {/* 油价表格 - 按城市显示 */}
          <div className="card overflow-hidden">
            <div className="p-3 bg-gray-50 border-b font-medium text-sm">
              {province} - 各市油价
            </div>
            <table className="w-full">
              <thead className="bg-gray-50">
                <tr>
                  <th className="p-3 text-left text-sm text-gray-600">城市</th>
                  <th className="p-3 text-right text-sm text-gray-600">92#</th>
                  <th className="p-3 text-right text-sm text-gray-600">95#</th>
                  <th className="p-3 text-right text-sm text-gray-600">98#</th>
                  <th className="p-3 text-right text-sm text-gray-600">0#</th>
                </tr>
              </thead>
              <tbody>
                {cities.slice(0, 10).map((c, i) => (
                  <tr key={c} className={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                    <td className="p-3 text-sm">{c}</td>
                    <td className="p-3 text-right text-sm font-medium">{CITY_DATA[c]?.['92'] || oilData[province]?.['92'] || '--'}</td>
                    <td className="p-3 text-right text-sm font-medium">{CITY_DATA[c]?.['95'] || oilData[province]?.['95'] || '--'}</td>
                    <td className="p-3 text-right text-sm font-medium">{CITY_DATA[c]?.['98'] || oilData[province]?.['98'] || '--'}</td>
                    <td className="p-3 text-right text-sm font-medium">{CITY_DATA[c]?.['0'] || oilData[province]?.['0'] || '--'}</td>
                  </tr>
                ))}
              </tbody>
            </table>
            {cities.length > 10 && (
              <div className="p-3 text-center text-sm text-gray-400">
                还有 {cities.length - 10} 个城市...
              </div>
            )}
          </div>

          <div className="text-center text-xs text-gray-400 mt-4">
            数据来源: qiyoujiage.com · 更新时间: {updateTime}
          </div>
        </div>
      );
    }


    // 智能建议组件
    function SmartSuggestion({ province, oilType, oilData }) {
      const [suggestion, setSuggestion] = useState({ text: '加载中...', type: 'normal' });
      
      useEffect(() => {
        // 获取历史数据分析
        fetch(API_BASE + '/price-changes?province=' + encodeURIComponent(province) + '&days=7')
          .then(res => res.json())
          .then(data => {
            const history = data.history || {};
            const dates = Object.keys(history).sort();
            
            if (dates.length < 2) {
              setSuggestion({ text: '数据不足，无法分析，建议保持正常加油节奏', type: 'normal' });
              return;
            }
            
            // 计算趋势
            const prices = dates.map(d => history[d]?.[oilType]).filter(p => p != null);
            if (prices.length < 2) {
              setSuggestion({ text: '近期数据不足，建议关注油价变化', type: 'normal' });
              return;
            }
            
            const latestPrice = prices[prices.length - 1];
            const earliestPrice = prices[0];
            const change = latestPrice - earliestPrice;
            const changePercent = (change / earliestPrice * 100).toFixed(1);
            
            // 生成智能建议
            let advice = '';
            let type = 'normal';
            
            if (change > 0.1) {
              // 上涨趋势
              if (changePercent > 3) {
                advice = `📢 <strong>建议：</strong>近期油价上涨明显(+${change.toFixed(2)}元, ${changePercent}%)，建议提前加满油`;
                type = 'rise';
              } else {
                advice = `📢 <strong>建议：</strong>油价小幅上涨(+${change.toFixed(2)}元)，可考虑适当提前加油`;
                type = 'rise';
              }
            } else if (change < -0.1) {
              // 下跌趋势
              if (changePercent < -3) {
                advice = `📢 <strong>建议：</strong>油价明显下跌(-${Math.abs(change).toFixed(2)}元, ${Math.abs(changePercent)}%)，可等待更低价格`;
                type = 'fall';
              } else {
                advice = `📢 <strong>建议：</strong>油价小幅下降(-${Math.abs(change).toFixed(2)}元)，可按需加油`;
                type = 'fall';
              }
            } else {
              // 平稳
              const volatility = Math.max(...prices) - Math.min(...prices);
              if (volatility > 0.3) {
                advice = `📢 <strong>建议：</strong>油价波动较大，建议关注价格变化，择时加油`;
              } else {
                advice = `📢 <strong>建议：</strong>油价平稳，近期无大幅波动，可按正常节奏加油`;
              }
            }
            
            setSuggestion({ text: advice, type });
          })
          .catch(() => {
            setSuggestion({ text: '数据加载失败，建议保持正常加油节奏', type: 'normal' });
          });
      }, [province, oilType]);
      
      const bgColor = suggestion.type === 'rise' ? 'bg-red-50 border-red-200' : 
                      suggestion.type === 'fall' ? 'bg-green-50 border-green-200' : 
                      'bg-amber-50 border-amber-200';
      const textColor = suggestion.type === 'rise' ? 'text-red-800' : 
                        suggestion.type === 'fall' ? 'text-green-800' : 
                        'text-amber-800';
      
      return (
        <div className={"mt-4 p-3 rounded-lg border " + bgColor}>
          <div className={"text-sm " + textColor} dangerouslySetInnerHTML={{ __html: suggestion.text }} />
        </div>
      );
    }

    // 趋势分析页
    function TrendPage({ selectedRegion }) {
      const chartRef = useRef(null);
      const [trendData, setTrendData] = useState([]);
      const [loading, setLoading] = useState(true);
      const [days, setDays] = useState(7); // 默认7天
      
      // 获取历史趋势数据
      useEffect(() => {
        fetch(API_BASE + '/price-changes?province=' + encodeURIComponent(selectedRegion) + '&days=' + days)
          .then(res => res.json())
          .then(data => {
            if (data.history) {
              const dates = Object.keys(data.history).sort();
              const trend = dates.map(date => ({
                date: date.slice(5),
                '92': data.history[date]['92'] || null,
                '95': data.history[date]['95'] || null,
                '0': data.history[date]['0'] || null,
              }));
              setTrendData(trend);
            }
            setLoading(false);
          })
          .catch(err => {
            console.error('获取趋势数据失败:', err);
            setLoading(false);
          });
      }, [selectedRegion, days]);
      
      useEffect(() => {
        if (!chartRef.current || loading || trendData.length === 0) return;
        const chart = echarts.init(chartRef.current);
        
        const validData = trendData.filter(d => d['92']);
        
        const option = {
          tooltip: { trigger: 'axis' },
          legend: { data: ['92#汽油', '95#汽油', '0#柴油'] },
          grid: { left: '3%', right: '4%', bottom: '3%', containLabel: true },
          xAxis: { type: 'category', data: validData.map(d => d.date) },
          yAxis: { type: 'value', scale: true },
          series: [
            { name: '92#汽油', type: 'line', data: validData.map(d => d['92']), smooth: true },
            { name: '95#汽油', type: 'line', data: validData.map(d => d['95']), smooth: true },
            { name: '0#柴油', type: 'line', data: validData.map(d => d['0']), smooth: true },
          ]
        };
        
        chart.setOption(option);
        return () => chart.dispose();
      }, [trendData, loading]);

      if (loading) {
        return <div className="p-4 text-center text-gray-500">加载中...</div>;
      }
      
      return (
        <div className="p-4 pb-20">
          <h2 className="text-xl font-bold mb-4">油价走势分析</h2>
          
          <div className="card p-4 mb-4">
            <div className="flex gap-2 mb-4">
              <button 
                onClick={() => setDays(7)}
                className={"px-4 py-2 rounded-lg text-sm " + (days === 7 ? 'bg-blue-600 text-white' : 'bg-white border')}
              >7天</button>
              <button 
                onClick={() => setDays(30)}
                className={"px-4 py-2 rounded-lg text-sm " + (days === 30 ? 'bg-blue-600 text-white' : 'bg-white border')}
              >30天</button>
            </div>
            <div ref={chartRef} style={{ height: '300px' }}></div>
          </div>

          <div className="card p-4">
            <h3 className="font-semibold mb-3">📊 趋势分析</h3>
            <div className="space-y-3 text-sm">
              <div className="flex justify-between">
                <span className="text-gray-600">7日趋势</span>
                <span className="price-up">↑ 上涨 0.07元</span>
              </div>
              <div className="flex justify-between">
                <span className="text-gray-600">30日趋势</span>
                <span className="price-down">↓ 下跌 0.12元</span>
              </div>
              <div className="flex justify-between">
                <span className="text-gray-600">今年最大波动</span>
                <span>0.35元</span>
              </div>
            </div>
          </div>

          <div className="card p-4 mt-4">
            <h3 className="font-semibold mb-3">💡 智能建议</h3>
            <div className="text-sm text-gray-600 space-y-2">
              <p>• 近期油价波动较小，建议保持正常加油节奏</p>
              <p>• 关注下周发改委调价窗口，预计变化幅度不超过50元/吨</p>
              <p>• 私营加油站常有优惠，可对比后选择</p>
            </div>
          </div>
        </div>
      );
    }

    // 附近加油页
    function StationPage({ isLoggedIn }) {
      const mapRef = useRef(null);
      const [map, setMap] = useState(null);
      const [userLocation, setUserLocation] = useState(null);
      const [stations, setStations] = useState([]);
      const [loading, setLoading] = useState(true);
      const [subscribedIds, setSubscribedIds] = useState([]);
      const [radius, setRadius] = useState(3); // 订阅半径(公里)

      // 加载用户订阅
      useEffect(() => {
        if (isLoggedIn) {
          const token = localStorage.getItem('auth_token');
          fetch('http://localhost:3000/api/stations/subscriptions', {
            headers: { Authorization: `Bearer ${token}` }
          })
            .then(res => res.json())
            .then(data => {
              if (data.success) {
                setSubscribedIds(data.subscriptions.map(s => s.stationId));
              }
            })
            .catch(() => {});
        }
      }, [isLoggedIn]);

      useEffect(() => {
        if (!mapRef.current || map) return;
        
        const center = new TMap.LatLng(39.908823, 116.397470);
        const mapInstance = new TMap.Map(mapRef.current, {
          center: center,
          zoom: 13,
        });
        setMap(mapInstance);
        
        if (navigator.geolocation) {
          navigator.geolocation.getCurrentPosition(
            (position) => {
              const { latitude, longitude } = position.coords;
              const userLatLng = new TMap.LatLng(latitude, longitude);
              setUserLocation({ lat: latitude, lng: longitude });
              mapInstance.setCenter(userLatLng);
              mapInstance.setZoom(14);
              
              new TMap.MultiMarker({
                map: mapInstance,
                geometries: [{
                  id: 'user',
                  position: userLatLng,
                  icon: '📍',
                }]
              });
              
              searchNearbyStations(latitude, longitude, mapInstance);
            },
            () => {
              searchNearbyStations(39.908823, 116.397470, mapInstance);
            }
          );
        } else {
          searchNearbyStations(39.908823, 116.397470, mapInstance);
        }
        
        return () => { if (mapInstance) mapInstance.destroy(); };
      }, []);

      const searchNearbyStations = async (lat, lng, mapInstance) => {
        setLoading(true);
        try {
          const res = await fetch(`http://localhost:3000/api/stations/nearby?lat=${lat}&lng=${lng}`);
          const data = await res.json();
          if (data.success && data.stations) {
            // 前端也计算真实距离
            const stationsWithDistance = data.stations.map(s => {
              const distance = calculateDistance(lat, lng, s.lat, s.lng);
              return {
                ...s,
                distance: formatDistance(distance),
                _distance: distance
              };
            });
            stationsWithDistance.sort((a, b) => a._distance - b._distance);
            setStations(stationsWithDistance);
            
            // 添加标记
            const stationMarkers = data.stations.map((station, i) => ({
              id: String(i),
              position: new TMap.LatLng(station.lat, station.lng),
              icon: '⛽',
            }));
            
            if (mapInstance) {
              new TMap.MultiMarker({ map: mapInstance, geometries: stationMarkers });
            }
          }
        } catch (e) {
          console.error('Failed to fetch stations:', e);
        }
        setLoading(false);
      };

      // 订阅/取消订阅加油站
      const toggleSubscribe = async (station) => {
        if (!isLoggedIn) {
          alert('请先登录');
          return;
        }
        
        const token = localStorage.getItem('auth_token');
        const isSubscribed = subscribedIds.includes(station.id);
        
        try {
          if (isSubscribed) {
            await fetch(`http://localhost:3000/api/stations/subscribe/${station.id}`, {
              method: 'DELETE',
              headers: { Authorization: `Bearer ${token}` }
            });
            setSubscribedIds(subscribedIds.filter(id => id !== station.id));
            alert('已取消订阅');
          } else {
            await fetch('http://localhost:3000/api/stations/subscribe', {
              method: 'POST',
              headers: { 
                'Content-Type': 'application/json',
                Authorization: `Bearer ${token}` 
              },
              body: JSON.stringify({ stationId: station.id, radius })
            });
            setSubscribedIds([...subscribedIds, station.id]);
            alert('订阅成功！当附近有优惠时会推送通知');
          }
        } catch (e) {
          alert('操作失败');
        }
      };

      const handleNavigate = (station) => {
        const url = `https://apis.map.qq.com/uri/v1/marker?marker=coord:${station.lat},${station.lng};name:${encodeURIComponent(station.name)}&referer=油价守护者`;
        window.location.href = url;
      };

      if (loading) {
        return <div className="p-4 text-center text-gray-500">加载中...</div>;
      }
      
      return (
        <div className="p-4 pb-20">
          <h2 className="text-xl font-bold mb-4">附近加油站</h2>
          
          {/* 地图 */}
          <div ref={mapRef} style={{ width: '100%', height: '300px' }} className="rounded-xl mb-4"></div>
          
          {/* 订阅设置 */}
          {isLoggedIn && (
            <div className="card mb-4 p-4">
              <div className="flex items-center justify-between">
                <span className="font-medium">订阅半径</span>
                <select 
                  value={radius} 
                  onChange={(e) => setRadius(e.target.value)}
                  className="p-2 border rounded"
                >
                  <option value="1">1公里</option>
                  <option value="2">2公里</option>
                  <option value="3">3公里</option>
                  <option value="5">5公里</option>
                </select>
              </div>
              <div className="text-xs text-gray-400 mt-2">
                订阅 {subscribedIds.length} 个加油站
              </div>
            </div>
          )}
          
          {/* 加油站列表 */}
          <div className="card overflow-hidden">
            {stations.map((station, i) => (
              <div key={i} className="p-4 border-b last:border-b-0">
                <div className="flex justify-between items-start mb-2">
                  <div className="flex-1">
                    <div className="font-medium">{station.name}</div>
                    <div className="text-xs text-gray-500">{station.address}</div>
                    {station.discount && station.discount !== '暂无优惠' && (
                      <div className="text-sm text-green-600 mt-1">🎉 {station.discount}</div>
                    )}
                  </div>
                  <div className="text-right">
                    <div className="text-lg font-bold price-down">{station.distance}</div>
                  </div>
                </div>
                
                <div className="flex gap-2 mt-2">
                  <button 
                    onClick={() => toggleSubscribe(station)}
                    className={`flex-1 py-2 rounded-lg text-sm ${
                      subscribedIds.includes(station.id) 
                        ? 'bg-green-100 text-green-600' 
                        : 'bg-blue-600 text-white'
                    }`}
                  >
                    {subscribedIds.includes(station.id) ? '✅ 已订阅' : '🔔 订阅优惠'}
                  </button>
                  <button 
                    onClick={() => handleNavigate(station)}
                    className="flex-1 py-2 bg-gray-100 text-gray-600 rounded-lg text-sm"
                  >
                    🧭 导航
                  </button>
                </div>
              </div>
            ))}
          </div>
        </div>
      );
    }
      );
    }

    // 油耗记录页
    // 油耗记录页面
    function FuelPage() {
      const STORAGE_KEY = 'oil_fuel_records';
      const [records, setRecords] = useState([]);
      const [loading, setLoading] = useState(true);
      const [showModal, setShowModal] = useState(false);
      const [newRecord, setNewRecord] = useState({
        date: new Date().toISOString().split('T')[0],
        km: '',
        fuel: '',
        pricePerL: '',
        price: ''
      });

      // 读取本地存储
      useEffect(() => {
        const stored = localStorage.getItem(STORAGE_KEY);
        if (stored) {
          setRecords(JSON.parse(stored));
        } else {
          // 初始化mock数据
          const mockData = [
            { date: '2026-03-15', km: 520, fuel: 42, pricePerL: 7.8, price: 328 },
            { date: '2026-03-10', km: 480, fuel: 38, pricePerL: 7.8, price: 298 },
          ];
          setRecords(mockData);
          localStorage.setItem(STORAGE_KEY, JSON.stringify(mockData));
        }
        setLoading(false);
      }, []);

      // 保存到本地存储
      const saveRecords = (data) => {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
        setRecords(data);
      };

      // 计算百公里油耗
      const avgConsumption = () => {
        if (records.length < 2) return '--';
        let totalFuel = 0;
        let totalKm = 0;
        for (let i = 1; i < records.length; i++) {
          totalFuel += records[i].fuel;
          totalKm += records[i].km;
        }
        if (totalKm === 0) return '--';
        return (totalFuel / totalKm * 100).toFixed(1);
      };

      // 计算平均花费
      const avgCost = () => {
        if (records.length === 0) return '--';
        const total = records.reduce((a, b) => a + b.price, 0);
        return (total / records.length).toFixed(0);
      };

      // 添加记录
      const addRecord = () => {
        const r = newRecord;
        if (!r.date || !r.km || !r.fuel || !r.price) {
          alert('请填写完整');
          return;
        }
        
        const newData = [{
          date: r.date,
          km: parseFloat(r.km),
          fuel: parseFloat(r.fuel),
          pricePerL: parseFloat(r.pricePerL) || (parseFloat(r.price) / parseFloat(r.fuel)),
          price: parseFloat(r.price)
        }, ...records];
        
        saveRecords(newData);
        setShowModal(false);
        setNewRecord({
          date: new Date().toISOString().split('T')[0],
          km: '',
          fuel: '',
          pricePerL: '',
          price: ''
        });
      };

      // 删除记录
      const deleteRecord = (index) => {
        if (confirm('确定要删除这条记录吗？')) {
          const newData = [...records];
          newData.splice(index, 1);
          saveRecords(newData);
        }
      };

      if (loading) {
        return <div className="p-4 text-center text-gray-500">加载中...</div>;
      }
      
      return (
        <div className="p-4 pb-20">
          {/* 统计卡片 */}
          <div className="grid grid-cols-2 gap-4 mb-4">
            <div className="card p-4 text-center">
              <div className="text-3xl font-bold text-blue-600">{avgConsumption()}</div>
              <div className="text-sm text-gray-500">百公里油耗(L)</div>
            </div>
            <div className="card p-4 text-center">
              <div className="text-3xl font-bold text-green-600">¥{avgCost()}</div>
              <div className="text-sm text-gray-500">平均单次加油(元)</div>
            </div>
          </div>

          {/* 加油记录 */}
          <div className="card mb-4">
            <div className="p-3 border-b font-medium flex justify-between items-center">
              <span>加油记录</span>
              <span className="text-sm text-gray-400">({records.length})</span>
            </div>
            
            {records.length === 0 && (
              <div className="p-8 text-center text-gray-400">暂无记录，点击下方按钮添加</div>
            )}
            
            {records.map((r, i) => (
              <div key={i} className="p-4 border-b last:border-b-0 flex justify-between items-center">
                <div>
                  <div className="text-sm text-gray-500">{r.date}</div>
                  <div className="text-sm">行驶 {r.km} 公里 · 加 {r.fuel}L · ¥{r.pricePerL}/L</div>
                </div>
                <div className="text-right">
                  <div className="font-medium text-lg">¥{r.price}</div>
                  <div 
                    className="text-sm text-red-500 cursor-pointer" 
                    onClick={() => deleteRecord(i)}
                  >
                    删除
                  </div>
                </div>
              </div>
            ))}
          </div>

          {/* 记录加油按钮 */}
          <button 
            className="w-full py-3 bg-blue-600 text-white rounded-xl mt-4"
            onClick={() => setShowModal(true)}
          >
            + 记录加油
          </button>

          {/* 添加记录弹窗 */}
          {showModal && (
            <div 
              className="fixed inset-0 bg-black/50 flex items-center justify-center z-50"
              onClick={() => setShowModal(false)}
            >
              <div 
                className="bg-white rounded-2xl p-6 w-[85%] max-h-[80vh] overflow-y-auto"
                onClick={e => e.stopPropagation()}
              >
                <div className="text-center font-bold text-lg mb-4">添加加油记录</div>
                
                <div className="mb-3">
                  <div className="text-sm text-gray-500 mb-1">日期</div>
                  <input 
                    type="date" 
                    className="w-full border rounded-lg p-2 text-sm"
                    value={newRecord.date}
                    onChange={e => setNewRecord({...newRecord, date: e.target.value})}
                  />
                </div>
                
                <div className="mb-3">
                  <div className="text-sm text-gray-500 mb-1">行驶里程(公里)</div>
                  <input 
                    type="number" 
                    className="w-full border rounded-lg p-2 text-sm"
                    placeholder="上次加油后行驶的里程"
                    value={newRecord.km}
                    onChange={e => setNewRecord({...newRecord, km: e.target.value})}
                  />
                </div>
                
                <div className="mb-3">
                  <div className="text-sm text-gray-500 mb-1">加油量(升)</div>
                  <input 
                    type="number" 
                    className="w-full border rounded-lg p-2 text-sm"
                    placeholder="本次加油的升数"
                    value={newRecord.fuel}
                    onChange={e => setNewRecord({...newRecord, fuel: e.target.value})}
                  />
                </div>
                
                <div className="mb-3">
                  <div className="text-sm text-gray-500 mb-1">油价(元/升)</div>
                  <input 
                    type="number" 
                    className="w-full border rounded-lg p-2 text-sm"
                    placeholder="单价"
                    value={newRecord.pricePerL}
                    onChange={e => setNewRecord({...newRecord, pricePerL: e.target.value})}
                  />
                </div>
                
                <div className="mb-4">
                  <div className="text-sm text-gray-500 mb-1">总价(元)</div>
                  <input 
                    type="number" 
                    className="w-full border rounded-lg p-2 text-sm"
                    placeholder="总价"
                    value={newRecord.price}
                    onChange={e => setNewRecord({...newRecord, price: e.target.value})}
                  />
                </div>
                
                <div className="flex gap-3">
                  <button 
                    className="flex-1 py-2 bg-gray-100 text-gray-600 rounded-lg"
                    onClick={() => setShowModal(false)}
                  >
                    取消
                  </button>
                  <button 
                    className="flex-1 py-2 bg-blue-600 text-white rounded-lg"
                    onClick={addRecord}
                  >
                    保存
                  </button>
                </div>
              </div>
            </div>
          )}
        </div>
      );
    }
    function MyPage({ isLoggedIn, userPhone, onLogout }) {
      const handleLogout = () => {
        if (confirm('确定要退出登录吗？')) {
          localStorage.removeItem('auth_token');
          localStorage.removeItem('user_phone');
          window.location.reload();
        }
      };

      const syncData = async () => {
        const token = localStorage.getItem('auth_token');
        if (!token) {
          alert('请先登录');
          return;
        }
        
        const records = localStorage.getItem('oil_fuel_records');
        const settings = localStorage.getItem('oil_remind_settings');
        
        try {
          if (records) {
            await fetch('http://localhost:3000/api/sync/fuel', {
              method: 'POST',
              headers: { 
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`
              },
              body: JSON.stringify({ records: JSON.parse(records) })
            });
          }
          if (settings) {
            await fetch('http://localhost:3000/api/sync/remind', {
              method: 'POST',
              headers: { 
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`
              },
              body: JSON.stringify({ settings: JSON.parse(settings) })
            });
          }
          alert('同步成功');
        } catch (e) {
          alert('同步失败');
        }
      };
      
      return (
        <div className="p-4 pb-20">
          <h2 className="text-xl font-bold mb-4">我的</h2>
          
          {/* 用户卡片 */}
          <div className="card p-4 mb-4">
            <div className="flex items-center gap-4">
              <div className="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center text-2xl">
                {isLoggedIn ? '🚗' : '👤'}
              </div>
              <div>
                <div className="font-semibold">{isLoggedIn ? userPhone : '点击登录'}</div>
                <div className="text-sm text-gray-500">{isLoggedIn ? '已登录' : '登录后同步数据'}</div>
              </div>
              {isLoggedIn && (
                <button 
                  className="ml-auto text-red-500 text-sm"
                  onClick={handleLogout}
                >
                  退出
                </button>
              )}
            </div>
          </div>

          <div className="card">
            <div className="p-4 border-b">
              <div className="flex items-center gap-3">
                <span className="text-xl">🔔</span>
                <span>油价提醒订阅</span>
              </div>
            </div>
            <div className="p-4 border-b">
              <div className="flex items-center gap-3">
                <span className="text-xl">⭐</span>
                <span>我的收藏油站</span>
              </div>
            </div>
            <div className="p-4 border-b" onClick={syncData}>
              <div className="flex items-center gap-3 cursor-pointer">
                <span className="text-xl">🔄</span>
                <span>手动同步数据</span>
              </div>
            </div>
            <div className="p-4 border-b">
              <div className="flex items-center gap-3">
                <span className="text-xl">⚙️</span>
                <span>设置</span>
              </div>
            </div>
            <div className="p-4">
              <div className="flex items-center gap-3">
                <span className="text-xl">❓</span>
                <span>帮助与反馈</span>
              </div>
            </div>
          </div>
        </div>
      );
    }
    }

    // 登录页面
    function LoginPage({ onLogin }) {
      const API_BASE = "http://localhost:3000/api";
      const [phone, setPhone] = useState('');
      const [code, setCode] = useState('');
      const [loading, setLoading] = useState(false);
      const [countdown, setCountdown] = useState(0);

      const sendCode = async () => {
        if (!/^1\d{10}$/.test(phone)) {
          alert('请输入正确手机号');
          return;
        }
        
        setCountdown(60);
        const timer = setInterval(() => {
          setCountdown(c => {
            if (c <= 1) {
              clearInterval(timer);
              return 0;
            }
            return c - 1;
          });
        }, 1000);
        
        try {
          const res = await fetch(`${API_BASE}/auth/code`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ phone })
          });
          const data = await res.json();
          if (data.success) {
            alert('验证码已发送');
          } else {
            alert(data.error);
          }
        } catch (e) {
          alert('网络错误');
        }
      };

      const login = async () => {
        if (!/^1\d{10}$/.test(phone)) {
          alert('请输入正确手机号');
          return;
        }
        if (!code || code.length < 4) {
          alert('请输入验证码');
          return;
        }
        
        setLoading(true);
        try {
          const res = await fetch(`${API_BASE}/auth/login`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ phone, code })
          });
          const data = await res.json();
          
          if (data.success) {
            localStorage.setItem('auth_token', data.token);
            localStorage.setItem('user_phone', data.user.phone);
            onLogin();
          } else {
            alert(data.error);
          }
        } catch (e) {
          alert('网络错误');
        }
        setLoading(false);
      };

      return (
        <div className="min-h-screen bg-gray-100 flex items-center justify-center p-4">
          <div className="bg-white rounded-2xl p-8 w-full max-w-sm">
            <div className="text-center mb-8">
              <div className="text-6xl mb-4">🚗</div>
              <div className="text-2xl font-bold">油价守护者</div>
              <div className="text-gray-400 text-sm mt-2">登录后同步油耗数据</div>
            </div>

            <div className="mb-4">
              <div className="text-sm text-gray-500 mb-1">手机号</div>
              <input 
                type="tel" 
                className="w-full border rounded-lg p-3 text-sm"
                placeholder="请输入手机号"
                value={phone}
                onChange={e => setPhone(e.target.value)}
                maxLength={11}
              />
            </div>

            <div className="mb-6">
              <div className="text-sm text-gray-500 mb-1">验证码</div>
              <div className="flex gap-2">
                <input 
                  type="tel" 
                  className="flex-1 border rounded-lg p-3 text-sm"
                  placeholder="请输入验证码"
                  value={code}
                  onChange={e => setCode(e.target.value)}
                  maxLength={6}
                />
                <button 
                  className="px-4 bg-blue-600 text-white rounded-lg text-sm whitespace-nowrap"
                  onClick={sendCode}
                  disabled={countdown > 0}
                >
                  {countdown > 0 ? `${countdown}s` : '获取验证码'}
                </button>
              </div>
            </div>

            <button 
              className="w-full py-3 bg-blue-600 text-white rounded-xl font-medium"
              onClick={login}
              disabled={loading}
            >
              {loading ? '登录中...' : '登录'}
            </button>

            <div className="text-center text-gray-400 text-sm mt-4">
              未注册的手机号将自动创建账号
            </div>
          </div>
        </div>
      );
    }
    // 主应用
    // 消息提醒页面
    function RemindPage() {
      const STORAGE_KEY = 'oil_remind_settings';
      const [settings, setSettings] = useState({
        oilRise: true,
        oilFall: true,
        fuelRemind: false,
        fuelThreshold: 8.5,
        maintainRemind: false,
        maintainKm: 5000,
        subscribeMsg: false
      });

      useEffect(() => {
        const stored = localStorage.getItem(STORAGE_KEY);
        if (stored) {
          setSettings({ ...settings, ...JSON.parse(stored) });
        }
      }, []);

      const saveSettings = (newSettings) => {
        const s = { ...settings, ...newSettings };
        setSettings(s);
        localStorage.setItem(STORAGE_KEY, JSON.stringify(s));
      };

      return (
        <div className="p-4 pb-20">
          {/* 油价提醒 */}
          <div className="card mb-4">
            <div className="p-3 border-b font-bold">油价提醒</div>
            
            <div className="flex justify-between items-center p-3 border-b">
              <div>
                <div className="font-medium">油价上涨提醒</div>
                <div className="text-sm text-gray-400">油价上涨前推送通知</div>
              </div>
              <input 
                type="checkbox" 
                checked={settings.oilRise}
                onChange={(e) => saveSettings({ oilRise: e.target.checked })}
                className="w-5 h-5"
              />
            </div>
            
            <div className="flex justify-between items-center p-3">
              <div>
                <div className="font-medium">油价下跌提醒</div>
                <div className="text-sm text-gray-400">油价下调时推送通知</div>
              </div>
              <input 
                type="checkbox" 
                checked={settings.oilFall}
                onChange={(e) => saveSettings({ oilFall: e.target.checked })}
                className="w-5 h-5"
              />
            </div>
          </div>

          {/* 油耗提醒 */}
          <div className="card mb-4">
            <div className="p-3 border-b font-bold">油耗提醒</div>
            
            <div className="flex justify-between items-center p-3 border-b">
              <div>
                <div className="font-medium">加油提醒</div>
                <div className="text-sm text-gray-400">当油耗低于设定值时提醒</div>
              </div>
              <input 
                type="checkbox" 
                checked={settings.fuelRemind}
                onChange={(e) => saveSettings({ fuelRemind: e.target.checked })}
                className="w-5 h-5"
              />
            </div>
            
            {settings.fuelRemind && (
              <div className="p-3">
                <div className="text-sm text-gray-500 mb-1">提醒阈值(L/百公里)</div>
                <input 
                  type="number" 
                  className="w-full border rounded-lg p-2 text-sm"
                  value={settings.fuelThreshold}
                  onChange={(e) => saveSettings({ fuelThreshold: e.target.value })}
                />
              </div>
            )}
          </div>

          {/* 保养提醒 */}
          <div className="card mb-4">
            <div className="p-3 border-b font-bold">保养提醒</div>
            
            <div className="flex justify-between items-center p-3 border-b">
              <div>
                <div className="font-medium">保养到期提醒</div>
                <div className="text-sm text-gray-400">按里程或时间提醒保养</div>
              </div>
              <input 
                type="checkbox" 
                checked={settings.maintainRemind}
                onChange={(e) => saveSettings({ maintainRemind: e.target.checked })}
                className="w-5 h-5"
              />
            </div>
            
            {settings.maintainRemind && (
              <div className="p-3">
                <div className="text-sm text-gray-500 mb-1">保养间隔(公里)</div>
                <input 
                  type="number" 
                  className="w-full border rounded-lg p-2 text-sm"
                  value={settings.maintainKm}
                  onChange={(e) => saveSettings({ maintainKm: e.target.value })}
                />
              </div>
            )}
          </div>

          {/* 通知方式 */}
          <div className="card">
            <div className="p-3 border-b font-bold">通知方式</div>
            
            <div className="flex justify-between items-center p-3">
              <div>
                <div className="font-medium">推送通知</div>
                <div className="text-sm text-gray-400">接收App推送消息</div>
              </div>
              <input 
                type="checkbox" 
                checked={settings.subscribeMsg}
                onChange={(e) => saveSettings({ subscribeMsg: e.target.checked })}
                className="w-5 h-5"
              />
            </div>
          </div>

          <div className="text-center text-gray-400 text-sm mt-4">
            设置已自动保存
          </div>
        </div>
      );
    }
    function App() {
      const [tab, setTab] = useState('price');
      const [selectedRegion, setSelectedRegion] = useState('北京');
      const [isLoggedIn, setIsLoggedIn] = useState(false);
      const [userPhone, setUserPhone] = useState('');

      useEffect(() => {
        const token = localStorage.getItem('auth_token');
        const phone = localStorage.getItem('user_phone');
        setIsLoggedIn(!!token);
        setUserPhone(phone || '');
      }, []);

      const handleLogin = () => {
        const token = localStorage.getItem('auth_token');
        const phone = localStorage.getItem('user_phone');
        setIsLoggedIn(!!token);
        setUserPhone(phone || '');
        // 同步数据到服务器
        syncToServer();
      };

      const syncToServer = async () => {
        const token = localStorage.getItem('auth_token');
        if (!token) return;
        
        const records = localStorage.getItem('oil_fuel_records');
        const settings = localStorage.getItem('oil_remind_settings');
        
        try {
          if (records) {
            await fetch('http://localhost:3000/api/sync/fuel', {
              method: 'POST',
              headers: { 
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`
              },
              body: JSON.stringify({ records: JSON.parse(records) })
            });
          }
          if (settings) {
            await fetch('http://localhost:3000/api/sync/remind', {
              method: 'POST',
              headers: { 
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`
              },
              body: JSON.stringify({ settings: JSON.parse(settings) })
            });
          }
        } catch (e) {
          console.log('同步失败', e);
        }
      };

      const handleLogout = () => {
        if (confirm('确定要退出登录吗？')) {
          localStorage.removeItem('auth_token');
          localStorage.removeItem('user_phone');
          setIsLoggedIn(false);
          setUserPhone('');
        }
      };

      const tabs = [
        { id: 'price', name: '油价', icon: '⛽' },
        { id: 'trend', name: '趋势', icon: '📈' },
        { id: 'station', name: '加油', icon: '🏪' },
        { id: 'fuel', name: '油耗', icon: '📊' },
        { id: 'my', name: '我的', icon: '👤' },
        { id: 'remind', name: '提醒', icon: '🔔' },
      ];

      if (loading) {
        return <div className="p-4 text-center text-gray-500">加载中...</div>;
      }

      // 未登录显示登录页
      if (!isLoggedIn) {
        return <LoginPage onLogin={handleLogin} />;
      }
      
      return (
        <div className="max-w-md mx-auto bg-gray-50 min-h-screen">
          {/* 顶部导航 */}
          <div className="bg-white shadow-sm sticky top-0 z-10">
            <div className="px-4 py-3 text-center font-bold text-lg">油价守护者</div>
          </div>

          {/* 页面内容 */}
          {tab === 'price' && <OilPricePage selectedRegion={selectedRegion} setSelectedRegion={setSelectedRegion} />}
          {tab === 'trend' && <TrendPage selectedRegion={selectedRegion} />}
          {tab === 'station' && <StationPage isLoggedIn={isLoggedIn} />}
          {tab === 'fuel' && <FuelPage />}
          {tab === 'my' && <MyPage isLoggedIn={isLoggedIn} userPhone={userPhone} onLogout={handleLogout} />}
          {tab === 'remind' && <RemindPage />}

          {/* 底部导航 */}
          <div className="fixed bottom-0 left-0 right-0 bg-white border-t">
            <div className="max-w-md mx-auto flex">
              {tabs.map(t => (
                <button
                  key={t.id}
                  onClick={() => setTab(t.id)}
                  className={`flex-1 py-3 text-center ${tab === t.id ? 'text-blue-600' : 'text-gray-400'}`}
                >
                  <div className="text-xl mb-1">{t.icon}</div>
                  <div className="text-xs">{t.name}</div>
                </button>
              ))}
            </div>
          </div>
        </div>
      );
    }
  </script>
</html>
