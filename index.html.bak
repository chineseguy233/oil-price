<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>油价守护者 - 智能油价监测</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
  <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/echarts@5.4.3/dist/echarts.min.js"></script>
  <style>
    :root {
      --primary: #2563EB;
      --rise: #EF4444;
      --fall: #22C55E;
      --bg: #F8FAFC;
    }
    body { background: var(--bg); font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
    .price-up { color: var(--rise); }
    .price-down { color: var(--fall); }
    .card { background: white; border-radius: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
    .tab-active { color: var(--primary); border-bottom: 3px solid var(--primary); }
  </style>
</head>
<body>
  <div id="root"></div>
  
  <script type="text/babel">
    const { useState, useEffect, useRef } = React;

    // 模拟油价数据
    const mockOilData = {
      '北京': { '92': 7.85, '95': 8.36, '98': 9.34, '0': 7.58 },
      '上海': { '92': 7.82, '95': 8.32, '98': 9.30, '0': 7.55 },
      '广东': { '92': 7.88, '95': 8.54, '98': 9.68, '0': 7.62 },
      '浙江': { '92': 7.83, '95': 8.33, '98': 9.14, '0': 7.56 },
      '江苏': { '92': 7.80, '95': 8.30, '98': 9.10, '0': 7.52 },
      '四川': { '92': 7.95, '95': 8.49, '98': 9.21, '0': 7.68 },
      '湖北': { '92': 7.78, '95': 8.34, '98': 9.22, '0': 7.48 },
      '河南': { '92': 7.75, '95': 8.28, '98': 9.10, '0': 7.45 },
    };

    const mockTrend7Days = [
      { date: '3-10', '92': 7.78, '95': 8.30, '0': 7.48 },
      { date: '3-11', '92': 7.80, '95': 8.32, '0': 7.50 },
      { date: '3-12', '92': 7.82, '95': 8.35, '0': 7.52 },
      { date: '3-13', '92': 7.85, '95': 8.36, '0': 7.55 },
      { date: '3-14', '92': 7.83, '95': 8.34, '0': 7.53 },
      { date: '3-15', '92': 7.85, '95': 8.36, '0': 7.58 },
      { date: '3-16', '92': 7.85, '95': 8.36, '0': 7.58 },
    ];

    // 首页 - 油价查询
    function OilPricePage({ selectedRegion, setSelectedRegion }) {
      const [oilType, setOilType] = useState('92');
      const regions = Object.keys(mockOilData);
      
      const currentPrice = mockOilData[selectedRegion]?.[oilType] || mockOilData['北京'][oilType];
      const yesterdayPrice = mockTrend7Days[5]?.[oilType] || currentPrice;
      const change = currentPrice - yesterdayPrice;
      const changePercent = ((change / yesterdayPrice) * 100).toFixed(2);

      return (
        <div className="p-4 pb-20">
          {/* 头部建议 */}
          <div className="card p-5 mb-4">
            <div className="text-sm text-gray-500 mb-1">今日油价 · {selectedRegion}</div>
            <div className="text-3xl font-bold text-gray-800 mb-2">
              {currentPrice} <span className="text-lg font-normal">元/升</span>
            </div>
            <div className={`text-sm ${change >= 0 ? 'price-up' : 'price-down'}`}>
              {change >= 0 ? '↑' : '↓'} 较昨日 {Math.abs(change)} 元 ({Math.abs(changePercent)}%)
            </div>
            <div className="mt-4 p-3 bg-amber-50 rounded-lg border border-amber-200">
              <div className="text-amber-800 text-sm">
                📢 <strong>建议：</strong>油价平稳，短期无大幅波动，周末出行可正常加油
              </div>
            </div>
          </div>

          {/* 地区选择 */}
          <div className="mb-4">
            <label className="text-sm text-gray-600 block mb-2">选择地区</label>
            <select 
              value={selectedRegion}
              onChange={(e) => setSelectedRegion(e.target.value)}
              className="w-full p-3 border rounded-xl bg-white"
            >
              {regions.map(r => <option key={r} value={r}>{r}</option>)}
            </select>
          </div>

          {/* 油号选择 */}
          <div className="flex gap-2 mb-4">
            {['92', '95', '98', '0'].map(type => (
              <button
                key={type}
                onClick={() => setOilType(type)}
                className={`flex-1 py-3 rounded-xl font-medium transition ${
                  oilType === type 
                    ? 'bg-blue-600 text-white' 
                    : 'bg-white text-gray-600 border'
                }`}
              >
                {type === '0' ? '0#柴油' : `${type}#汽油`}
              </button>
            ))}
          </div>

          {/* 油价表格 */}
          <div className="card overflow-hidden">
            <table className="w-full">
              <thead className="bg-gray-50">
                <tr>
                  <th className="p-3 text-left text-sm text-gray-600">地区</th>
                  <th className="p-3 text-right text-sm text-gray-600">92#</th>
                  <th className="p-3 text-right text-sm text-gray-600">95#</th>
                  <th className="p-3 text-right text-sm text-gray-600">98#</th>
                  <th className="p-3 text-right text-sm text-gray-600">0#</th>
                </tr>
              </thead>
              <tbody>
                {regions.map((region, i) => (
                  <tr key={region} className={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                    <td className="p-3 text-sm">{region}</td>
                    <td className="p-3 text-right text-sm font-medium">{mockOilData[region]['92']}</td>
                    <td className="p-3 text-right text-sm font-medium">{mockOilData[region]['95']}</td>
                    <td className="p-3 text-right text-sm">{mockOilData[region]['98']}</td>
                    <td className="p-3 text-right text-sm">{mockOilData[region]['0']}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          
          <div className="text-center text-xs text-gray-400 mt-4">
            数据来源：国家发改委 · 更新时间：{new Date().toLocaleTimeString('zh-CN', {hour: '2-digit', minute:'2-digit'})}
          </div>
        </div>
      );
    }

    // 趋势分析页
    function TrendPage() {
      const chartRef = useRef(null);
      
      useEffect(() => {
        if (!chartRef.current) return;
        const chart = echarts.init(chartRef.current);
        
        const option = {
          tooltip: { trigger: 'axis' },
          legend: { data: ['92#汽油', '95#汽油', '0#柴油'] },
          grid: { left: '3%', right: '4%', bottom: '3%', containLabel: true },
          xAxis: { type: 'category', data: mockTrend7Days.map(d => d.date) },
          yAxis: { type: 'value', min: 7.4, max: 8.6, scale: true },
          series: [
            { name: '92#汽油', type: 'line', data: mockTrend7Days.map(d => d['92']), smooth: true },
            { name: '95#汽油', type: 'line', data: mockTrend7Days.map(d => d['95']), smooth: true },
            { name: '0#柴油', type: 'line', data: mockTrend7Days.map(d => d['0']), smooth: true },
          ]
        };
        
        chart.setOption(option);
        return () => chart.dispose();
      }, []);

      return (
        <div className="p-4 pb-20">
          <h2 className="text-xl font-bold mb-4">油价走势分析</h2>
          
          <div className="card p-4 mb-4">
            <div className="flex gap-2 mb-4">
              <button className="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm">7天</button>
              <button className="px-4 py-2 bg-white border rounded-lg text-sm">30天</button>
            </div>
            <div ref={chartRef} style={{ height: '300px' }}></div>
          </div>

          <div className="card p-4">
            <h3 className="font-semibold mb-3">📊 趋势分析</h3>
            <div className="space-y-3 text-sm">
              <div className="flex justify-between">
                <span className="text-gray-600">7日趋势</span>
                <span className="price-up">↑ 上涨 0.07元</span>
              </div>
              <div className="flex justify-between">
                <span className="text-gray-600">30日趋势</span>
                <span className="price-down">↓ 下跌 0.12元</span>
              </div>
              <div className="flex justify-between">
                <span className="text-gray-600">今年最大波动</span>
                <span>0.35元</span>
              </div>
            </div>
          </div>

          <div className="card p-4 mt-4">
            <h3 className="font-semibold mb-3">💡 智能建议</h3>
            <div className="text-sm text-gray-600 space-y-2">
              <p>• 近期油价波动较小，建议保持正常加油节奏</p>
              <p>• 关注下周发改委调价窗口，预计变化幅度不超过50元/吨</p>
              <p>• 私营加油站常有优惠，可对比后选择</p>
            </div>
          </div>
        </div>
      );
    }

    // 附近加油页
    function StationPage() {
      const stations = [
        { name: '中石化加油站(朝阳路站)', distance: '0.8km', price: 7.65, address: '朝阳区朝阳路128号' },
        { name: '中石油加油站(海淀站)', distance: '1.2km', price: 7.72, address: '海淀区中关村大街' },
        { name: '壳牌加油站(东城站)', distance: '1.5km', price: 7.58, address: '东城区东直门南大街' },
        { name: '民营加油站(实惠站)', distance: '2.0km', price: 7.45, address: '丰台区南三环' },
      ];

      return (
        <div className="p-4 pb-20">
          <h2 className="text-xl font-bold mb-4">附近加油站</h2>
          
          <div className="card overflow-hidden">
            {stations.map((station, i) => (
              <div key={i} className="p-4 border-b last:border-b-0">
                <div className="flex justify-between items-start mb-2">
                  <div>
                    <div className="font-medium">{station.name}</div>
                    <div className="text-xs text-gray-500">{station.address}</div>
                  </div>
                  <div className="text-right">
                    <div className="text-lg font-bold price-down">{station.price}</div>
                    <div className="text-xs text-gray-400">{station.distance}</div>
                  </div>
                </div>
                <button className="w-full py-2 bg-blue-600 text-white rounded-lg text-sm mt-2">
                  导航到这儿
                </button>
              </div>
            ))}
          </div>

          <div className="mt-4 text-center text-sm text-gray-500">
            💡 建议：私营加油站价格通常比两桶油低0.2-0.5元/升
          </div>
        </div>
      );
    }

    // 油耗记录页
    function FuelPage() {
      const [records, setRecords] = useState([
        { date: '2026-03-15', km: 520, fuel: 42, price: 328 },
        { date: '2026-03-10', km: 480, fuel: 38, price: 298 },
        { date: '2026-03-05', km: 550, fuel: 44, price: 345 },
      ]);

      const avgConsumption = (records.reduce((a, b) => a + b.fuel, 0) / records.reduce((a, b) => a + b.km, 0) * 100).toFixed(1);
      const avgCost = (records.reduce((a, b) => a + b.price, 0) / records.length).toFixed(0);

      return (
        <div className="p-4 pb-20">
          <h2 className="text-xl font-bold mb-4">油耗记录</h2>
          
          <div className="grid grid-cols-2 gap-4 mb-4">
            <div className="card p-4 text-center">
              <div className="text-3xl font-bold text-blue-600">{avgConsumption}</div>
              <div className="text-sm text-gray-500">百公里油耗(L)</div>
            </div>
            <div className="card p-4 text-center">
              <div className="text-3xl font-bold text-green-600">¥{avgCost}</div>
              <div className="text-sm text-gray-500">平均单次加油(元)</div>
            </div>
          </div>

          <div className="card">
            <div className="p-3 border-b font-medium">加油记录</div>
            {records.map((r, i) => (
              <div key={i} className="p-4 border-b last:border-b-0 flex justify-between items-center">
                <div>
                  <div className="text-sm text-gray-500">{r.date}</div>
                  <div className="text-sm">行驶 {r.km} 公里 · 加 {r.fuel}L</div>
                </div>
                <div className="font-medium">¥{r.price}</div>
              </div>
            ))}
          </div>

          <button className="w-full py-3 bg-blue-600 text-white rounded-xl mt-4">
            + 记录加油
          </button>
        </div>
      );
    }

    // 我的页面
    function MyPage() {
      return (
        <div className="p-4 pb-20">
          <h2 className="text-xl font-bold mb-4">我的</h2>
          
          <div className="card p-4 mb-4">
            <div className="flex items-center gap-4">
              <div className="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center text-2xl">
                🚗
              </div>
              <div>
                <div className="font-semibold">车主用户</div>
                <div className="text-sm text-gray-500">注册于 2026-03-08</div>
              </div>
            </div>
          </div>

          <div className="card">
            <div className="p-4 border-b">
              <div className="flex items-center gap-3">
                <span className="text-xl">🔔</span>
                <span>油价提醒订阅</span>
              </div>
            </div>
            <div className="p-4 border-b">
              <div className="flex items-center gap-3">
                <span className="text-xl">⭐</span>
                <span>我的收藏油站</span>
              </div>
            </div>
            <div className="p-4 border-b">
              <div className="flex items-center gap-3">
                <span className="text-xl">⚙️</span>
                <span>设置</span>
              </div>
            </div>
            <div className="p-4">
              <div className="flex items-center gap-3">
                <span className="text-xl">� Help</span>
                <span>帮助与反馈</span>
              </div>
            </div>
          </div>
        </div>
      );
    }

    // 主应用
    function App() {
      const [tab, setTab] = useState('price');
      const [selectedRegion, setSelectedRegion] = useState('北京');

      const tabs = [
        { id: 'price', name: '油价', icon: '⛽' },
        { id: 'trend', name: '趋势', icon: '📈' },
        { id: 'station', name: '加油', icon: '🏪' },
        { id: 'fuel', name: '油耗', icon: '📊' },
        { id: 'my', name: '我的', icon: '👤' },
      ];

      return (
        <div className="max-w-md mx-auto bg-gray-50 min-h-screen">
          {/* 顶部导航 */}
          <div className="bg-white shadow-sm sticky top-0 z-10">
            <div className="px-4 py-3 text-center font-bold text-lg">油价守护者</div>
          </div>

          {/* 页面内容 */}
          {tab === 'price' && <OilPricePage selectedRegion={selectedRegion} setSelectedRegion={setSelectedRegion} />}
          {tab === 'trend' && <TrendPage />}
          {tab === 'station' && <StationPage />}
          {tab === 'fuel' && <FuelPage />}
          {tab === 'my' && <MyPage />}

          {/* 底部导航 */}
          <div className="fixed bottom-0 left-0 right-0 bg-white border-t">
            <div className="max-w-md mx-auto flex">
              {tabs.map(t => (
                <button
                  key={t.id}
                  onClick={() => setTab(t.id)}
                  className={`flex-1 py-3 text-center ${tab === t.id ? 'text-blue-600' : 'text-gray-400'}`}
                >
                  <div className="text-xl mb-1">{t.icon}</div>
                  <div className="text-xs">{t.name}</div>
                </button>
              ))}
            </div>
          </div>
        </div>
      );
    }

    ReactDOM.createRoot(document.getElementById('root')).render(<App />);
  </script>
</body>
</html>
